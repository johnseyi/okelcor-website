{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./*.key)",
      "Read(./*.pem)",
      "Read(./*.p12)",
      "Read(./node_modules/**)",
      "Read(./.next/**)",
      "Read(./dist/**)",
      "Read(./build/**)"
    ],
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run test *)",
      "Bash(npm run dev)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run build)",
      "Bash(pnpm run test *)",
      "Bash(pnpm run dev)",
      "Bash(yarn lint)",
      "Bash(yarn build)",
      "Bash(yarn test *)",
      "Bash(yarn dev)"
    ]
  }
}
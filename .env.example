# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=

# The "from" address used in all outgoing emails.
# Must be a domain verified in your Resend account.
FROM_EMAIL=Okelcor Website <noreply@yourdomain.com>

# Where contact-form messages are delivered
CONTACT_EMAIL=info@yourdomain.com

# Where quote-request emails are delivered (falls back to CONTACT_EMAIL)
QUOTE_EMAIL=quotes@yourdomain.com

# ─── Auth (NextAuth.js) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Full URL of the deployment (no trailing slash)
NEXTAUTH_URL=https://your-domain.com

# ─── Stripe — Card / Apple Pay / Google Pay ───────────────────────────────────
# https://dashboard.stripe.com/apikeys
# Set both keys to enable card, Apple Pay, and Google Pay in checkout.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ─── PayPal ───────────────────────────────────────────────────────────────────
# https://developer.paypal.com/dashboard/applications
# Set both keys to enable PayPal in checkout.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ─── Klarna (via Stripe) ──────────────────────────────────────────────────────
# Klarna runs through Stripe — STRIPE_SECRET_KEY must also be set.
# Set to "true" to surface Klarna as a payment option.
NEXT_PUBLIC_KLARNA_ENABLED=
